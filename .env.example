# Ollama local
# Este archivo es solo un ejemplo. Si necesitas claves reales, crea un .env aparte

OLLAMA_URL=http://localhost:11434/api
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# PoliGPT, solo para benchmark y evaluación RAGAs.
# Desde fuera del campus hace falta VPN UPV.
POLIGPT_BASE_URL=https://api.poligpt.upv.es/v1
POLIGPT_API_KEY=pon_aqui_tu_clave_solo_en_tu_.env_real